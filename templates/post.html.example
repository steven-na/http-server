<!DOCTYPE html>
<!-- Mostly AI Generated (Other than article content) -->
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@4/tex-mml-chtml.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const overlay = document.createElement('div');
      Object.assign(overlay.style, {
        display: 'none', position: 'fixed', inset: '0',
        background: 'rgba(0,0,0,0.85)', zIndex: '999',
        cursor: 'zoom-out', alignItems: 'center', justifyContent: 'center'
      });
  
      const lightboxImg = document.createElement('img');
      Object.assign(lightboxImg.style, {
        maxWidth: '90vw', maxHeight: '90vh',
        objectFit: 'contain', borderRadius: '2px'
      });
  
      overlay.appendChild(lightboxImg);
      document.body.appendChild(overlay);
  
      document.querySelectorAll('article > img').forEach(img => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => {
          lightboxImg.src = img.src;
          overlay.style.display = 'flex';
        });
      });
  
      overlay.addEventListener('click', () => {
        overlay.style.display = 'none';
        lightboxImg.src = '';
      });
  
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') overlay.click();
      });
    });
  </script>
    <script>
    (function() {
      var t = localStorage.getItem('theme') ||
              (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <title><!-- ARTICLE TITLE --></title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link id="hljs-light" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/base16/github.min.css">
  <link id="hljs-dark"  rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/base16/tomorrow-night.min.css" disabled>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Theme variables ── */
    :root {
      --bg:        #fafaf8;
      --fg:        #1a1a18;
      --muted:     #6b6b65;
      --border:    #e0dfd8;
      --code-bg:   #f0efeb;
      --accent:    #2d6a4f;
    }

    [data-theme="warm"] {
      --bg:        #fdf6e3;
      --fg:        #1a1a18;
      --muted:     #6b6b65;
      --border:    #e8e0cc;
      --code-bg:   #f0e8d0;
      --accent:    #2d6a4f;
    }

    [data-theme="dark"] {
      --bg:        #1a1916;
      --fg:        #e8e6e0;
      --muted:     #9a9890;
      --border:    #2e2d28;
      --code-bg:   #242320;
      --accent:    #52b788;
    }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: 'Lora', Georgia, serif;
      font-size: 17px;
      line-height: 1.75;
      padding: 0 1rem;
      transition: background 0.2s, color 0.2s;
    }

    /* ── Header ── */
    header {
      position: static;
      z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      transition: background 0.2s;
    }

    .header-inner {
      max-width: 90%;
      margin: 0 auto;
      padding: 1.25rem 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    header.is-sticky {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      animation: slide-down 0.2s ease;
    }

    header.is-unsticky {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      animation: slide-up 0.2s ease forwards;
    }

    @keyframes slide-down {
      from { transform: translateY(-100%); }
      to   { transform: translateY(0); }
    }

    @keyframes slide-up {
      from { transform: translateY(0); }
      to   { transform: translateY(-100%); }
    }

    .site-name {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      font-weight: 500;
      color: var(--fg);
      text-decoration: none;
    }

    .header-right {
      display: flex;
      align-items: center;
    }

    .theme-toggle {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0 0 0 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.73rem;
      color: var(--muted);
      transition: color 0.15s;
    }

    .theme-toggle:hover { color: var(--fg); }

    .theme-toggle svg {
      width: 14px;
      height: 14px;
      fill: currentColor;
      flex-shrink: 0;
    }

    .header-divider {
      width: 1px;
      height: 1.1rem;
      background: var(--border);
      margin: 0 0.6rem;
    }

    nav {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    nav a {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    nav a:hover { color: var(--fg); }

    /* ── Post hero ── */
    .post-hero {
      max-width: 80%;
      margin: 0 auto;
      padding: 3.5rem 0 2.5rem;
      border-bottom: 1px solid var(--border);
    }

    .post-hero h1 {
      font-size: 2.2rem;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 1.25rem;
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: var(--muted);
    }

    .post-meta span { white-space: nowrap; }

    /* ── Main / Article ── */
    main {
      max-width: 80%;
      margin: 0 auto;
      padding: 3.5rem 0 4rem;
    }

    article {
      max-width: 100%;
      overflow: hidden;
    }

    p  { margin-bottom: 1.2rem; }

    h1 { font-size: 1.9rem;  font-weight: 600; line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 2.5rem; }
    h2 { font-size: 1.15rem; font-weight: 600; margin: 2.5rem 0 0.75rem; color: var(--fg); }
    h3 { font-size: 1rem;    font-weight: 600; margin: 2rem 0 0.5rem;    color: var(--fg); }

    ul, ol { padding-left: 1.5rem; margin-bottom: 1.2rem; }
    li     { margin-bottom: 0.3rem; }

    a { color: var(--fg); }

    code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.82em;
      background: var(--code-bg);
      color: var(--fg);
      padding: 0.1em 0.35em;
      border-radius: 3px;
    }

    pre {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      line-height: 1.45;
      background: var(--code-bg);
      border-left: 3px solid var(--accent);
      padding: 0.85rem 1.2rem;
      overflow-x: auto;
      margin: 1.4rem 0;
    }

    pre code { background: none; padding: 0; font-size: inherit; line-height: inherit; }

    blockquote {
      border-left: 3px solid var(--border);
      margin: 1.4rem 0;
      padding: 0.3rem 0 0.3rem 1.2rem;
      color: var(--muted);
      font-style: italic;
    }

    .note {
      background: var(--code-bg);
      border-left: 3px solid var(--accent);
      padding: 0.8rem 1.1rem;
      margin: 1.4rem 0;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      line-height: 1.6;
    }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    /* ── Images ── */
    article > img {
      display: block;
      max-width: 100%;
      width: auto;
      height: auto;
      margin: 1.4rem auto;
      overflow: hidden;
    }
    
    article > img:has(+ img) {
      display: inline-block;
      width: auto;
      max-width: calc(50% - 0.4rem);
      height: auto;
      margin: 1.4rem 0.4rem 1.4rem 0;
      vertical-align: top;
    }
    
    article > img + img {
      display: inline-block;
      width: auto;
      max-width: calc(50% - 0.4rem);
      height: auto;
      margin: 1.4rem 0 1.4rem 0;
      vertical-align: top;
    }

    /* ── Footer ── */
    footer {
      max-width: 90%;
      margin: 0 auto;
      border-top: 1px solid var(--border);
      padding: 1.75rem 0 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.73rem;
      color: var(--muted);
    }

    .footer-left {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .footer-left a {
      color: var(--muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    .footer-left a:hover { color: var(--fg); }

    .footer-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .footer-icon {
      color: var(--muted);
      text-decoration: none;
      display: flex;
      align-items: center;
      transition: color 0.15s;
    }

    .footer-icon:hover { color: var(--fg); }

    .footer-icon svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    /* Scroll to top button */
    #scroll-top {
      background: none;
      border: 1px solid var(--border);
      border-radius: 3px;
      cursor: pointer;
      padding: 0.3rem 0.5rem;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.73rem;
      color: var(--muted);
      transition: color 0.15s, border-color 0.15s;
    }

    #scroll-top:hover { color: var(--fg); border-color: var(--fg); }

    #scroll-top svg {
      width: 12px;
      height: 12px;
      fill: currentColor;
    }

    /* ── Post navigation ── */
    .post-nav {
      max-width: 90%;
      margin: 0 auto;
      padding: 2.5rem 0;
      border-top: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .post-nav-link {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      text-decoration: none;
      padding: 1rem 1.1rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      transition: border-color 0.15s, background 0.15s;
    }

    .post-nav-link:hover {
      border-color: var(--fg);
      background: var(--code-bg);
    }

    .post-nav-link.prev { align-items: flex-start; }
    .post-nav-link.next { align-items: flex-end; grid-column: 2; }

    .post-nav-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .post-nav-label svg {
      width: 10px;
      height: 10px;
      fill: currentColor;
      flex-shrink: 0;
    }

    .post-nav-title {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.9rem;
      color: var(--fg);
      line-height: 1.35;
    }
  </style>
</head>
<body>

<header>
  <div class="header-inner">
    <a class="site-name" href="/">mysite.io</a>
    <div class="header-right">
      <nav>
        <a href="/posts/recent/">Recent Post</a>
      </nav>
      <div class="header-divider"></div>
      <button class="theme-toggle" id="themeToggle" title="Switch theme" aria-label="Switch theme">
        <svg id="themeIcon" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"/>
        </svg>
        <span id="themeLabel">light</span>
      </button>
    </div>
  </div>
</header>

<!-- Post hero populated by generator -->
<div class="post-hero" id="post-hero">
  <h1><!-- ARTICLE TITLE --></h1>
  <div class="post-meta">
    <span><!-- ARTICLE AUTHOR --></span>
    <span><!-- ARTICLE DATE --></span>
  </div>
</div>

<main>
  <article>
    <!-- ARTICLE CONTENT -->
  </article>
</main>

<nav class="post-nav" aria-label="Post navigation">
  <!-- REMOVE PREV POST START -->
  <a class="post-nav-link prev" href="/posts/PREVIOUS-POST-SLUG">
    <span class="post-nav-label">
      <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
      </svg>
      previous post
    </span>
    <span class="post-nav-title"><!-- PREVIOUS POST TITLE --></span>
  </a>
  <!-- REMOVE PREV POST END -->

  <!-- REMOVE NEXT POST START -->
  <a class="post-nav-link next" href="/posts/NEXT-POST-SLUG">
    <span class="post-nav-label">
      next post
      <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
      </svg>
    </span>
    <span class="post-nav-title"><!-- NEXT POST TITLE --></span>
  </a>
  <!-- REMOVE NEXT POST END -->
</nav>

<footer>
  <div class="footer-left">
    <span>Your Name</span>
    <!-- If it breaks, let me know! -->
    <a href="mailto:you@example.com">you@example.com</a>
  </div>
  <div class="footer-right">
    <!-- GitHub -->
    <a class="footer-icon" href="https://github.com" target="_blank" rel="noopener" aria-label="GitHub">
      <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </a>

    <!-- Scroll to top -->
    <button id="scroll-top" aria-label="Scroll to top">
      <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M8 15a.5.5 0 0 0 .5-.5V2.707l3.146 3.147a.5.5 0 0 0 .708-.708l-4-4a.5.5 0 0 0-.708 0l-4 4a.5.5 0 1 0 .708.708L7.5 2.707V14.5a.5.5 0 0 0 .5.5z"/>
      </svg>
      top
    </button>
  </div>
</footer>

<script>
  // ── Theme setup ────────────────────────────────────────────────
  const themes   = ['light', 'warm', 'dark'];
  const sunIcon  = `<path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"/>`;
  const warmIcon = `<path d="M8 3.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9zM1 8a7 7 0 1 1 14 0A7 7 0 0 1 1 8z"/><path d="M8 6a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-3.5 2a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>`;
  const moonIcon = `<path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z"/>`;
  const icons    = [sunIcon, warmIcon, moonIcon];

  const saved      = localStorage.getItem('theme');
  const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const initial    = saved || (systemDark ? 'dark' : 'light');
  let   current    = Math.max(themes.indexOf(initial), 0);

  function applyTheme(idx) {
    const t = themes[idx];
    document.documentElement.setAttribute('data-theme', t);
    document.getElementById('themeLabel').textContent = t;
    document.getElementById('themeIcon').innerHTML    = icons[idx];
    document.getElementById('hljs-light').disabled = (t === 'dark');
    document.getElementById('hljs-dark').disabled  = (t !== 'dark');
    localStorage.setItem('theme', t);
  }

  applyTheme(current);

  document.getElementById('themeToggle').addEventListener('click', () => {
    current = (current + 1) % themes.length;
    applyTheme(current);
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
    if (!localStorage.getItem('theme')) {
      current = themes.indexOf(e.matches ? 'dark' : 'light');
      applyTheme(current);
    }
  });

  // ── Sticky header ──────────────────────────────────────────────
  const hero   = document.getElementById('post-hero');
  const header = document.querySelector('header');

  const spacer = document.createElement('div');
  spacer.style.display = 'none';
  header.after(spacer);

  const headerH = header.offsetHeight;
  spacer.style.height = headerH + 'px';

  const observer = new IntersectionObserver(
    ([entry]) => {
      const sticky = !entry.isIntersecting;
      if (sticky) {
        spacer.style.display = 'block';
        header.classList.remove('is-unsticky');
        header.classList.add('is-sticky');
      } else {
        header.classList.remove('is-sticky');
        header.classList.add('is-unsticky');
        header.addEventListener('animationend', () => {
          header.classList.remove('is-unsticky');
          spacer.style.display = 'none';
        }, { once: true });
      }
    },
    { threshold: 0 }
  );
  observer.observe(hero);

  // ── Scroll to top ──────────────────────────────────────────────
  document.getElementById('scroll-top').addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── Highlight.js ───────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('pre code').forEach(block => hljs.highlightElement(block));
  });

</script>

</body>
</html>
